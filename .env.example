# Copy this file to .env.local and fill in real credentials before running the agent.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
# Optional organization for OpenAI-compatible providers
OPENAI_ORG=
# Optional timeout (milliseconds) before aborting LLM calls
OPENAI_TIMEOUT_MS=30000
