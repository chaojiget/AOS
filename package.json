{
  "name": "aos",
  "version": "0.1.0",
  "description": "Agent Operating System workspace",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "pnpm install",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "dev:api": "tsx watch servers/api/src/main.ts",
    "dev:all": "node scripts/dev-all.mjs",
    "build:api": "tsc -p servers/api/tsconfig.build.json",
    "start:api": "node servers/api/dist/main.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.cjs,.mjs",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/vitest-runner.mjs",
    "test:ui": "playwright test",
    "smoke": "node scripts/smoke.mjs",
    "replay": "node scripts/replay.mjs",
    "score": "node scripts/score.mjs",
    "intake": "node scripts/intake.mjs"
  },
  "keywords": [],
  "author": "",
  "packageManager": "pnpm@10.5.2",
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/terminus": "^10.2.2",
    "better-sqlite3": "^12.2.0",
    "drizzle-orm": "^0.44.5",
    "next": "^14.2.5",
    "openai": "^5.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.4",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.18",
    "@tsconfig/next": "^2.0.1",
    "@types/node": "^20.14.2",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "playwright": "^1.44.0",
    "postcss": "^8.5.6",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.19.1",
    "typescript": "^5.4.5",
    "vitest": "file:packages/vitest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "better-sqlite3",
      "esbuild"
    ]
  }
}
