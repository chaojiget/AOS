{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentOS SRS Schema",
  "type": "object",
  "required": [
    "meta",
    "value",
    "scope",
    "data",
    "experience",
    "non_functional",
    "security",
    "risk_register",
    "budget",
    "release",
    "acceptance",
    "test_data"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "title", "owner", "stakeholders"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "stakeholders": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "role"],
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "contact": { "type": "string" }
            }
          }
        }
      }
    },
    "value": {
      "type": "object",
      "required": ["business_goal", "metrics", "user_jobs"],
      "properties": {
        "business_goal": { "type": "string", "minLength": 1 },
        "metrics": {
          "type": "object",
          "required": ["north_star"],
          "properties": {
            "north_star": { "type": "string", "minLength": 1 },
            "guardrails": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "user_jobs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["persona", "job"],
            "properties": {
              "persona": { "type": "string" },
              "job": { "type": "string" },
              "pain_points": { "type": "string" }
            }
          }
        }
      }
    },
    "scope": {
      "type": "object",
      "required": ["must"],
      "properties": {
        "must": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "should": { "type": "array", "items": { "type": "string" } },
        "could": { "type": "array", "items": { "type": "string" } },
        "wont": { "type": "array", "items": { "type": "string" } }
      }
    },
    "data": {
      "type": "object",
      "required": ["sources", "interfaces", "masking"],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "interfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "masking": { "type": "string", "minLength": 1 }
      }
    },
    "experience": {
      "type": "object",
      "required": ["notes", "performance", "accessibility"],
      "properties": {
        "notes": { "type": "string" },
        "performance": { "type": "string" },
        "accessibility": { "type": "string" }
      }
    },
    "non_functional": {
      "type": "object",
      "required": ["observability", "logging", "resilience"],
      "properties": {
        "observability": { "type": "string" },
        "logging": { "type": "string" },
        "resilience": { "type": "string" }
      }
    },
    "security": {
      "type": "object",
      "required": ["classification", "permissions", "compliance"],
      "properties": {
        "classification": { "type": "string" },
        "permissions": { "type": "string" },
        "compliance": { "type": "string" }
      }
    },
    "risk_register": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "mitigation"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "mitigation": { "type": "string" }
        }
      }
    },
    "budget": {
      "type": "object",
      "required": ["limit", "sla", "governance"],
      "properties": {
        "limit": { "type": "string" },
        "sla": { "type": "string" },
        "governance": { "type": "string" }
      }
    },
    "release": {
      "type": "object",
      "required": ["plan", "rollback", "monitoring"],
      "properties": {
        "plan": { "type": "string" },
        "rollback": { "type": "string" },
        "monitoring": { "type": "string" }
      }
    },
    "acceptance": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "given", "when", "then"],
        "properties": {
          "id": { "type": "string" },
          "given": { "type": "string" },
          "when": { "type": "string" },
          "then": { "type": "string" }
        }
      }
    },
    "test_data": {
      "type": "object",
      "required": ["strategy"],
      "properties": {
        "strategy": { "type": "string" }
      }
    }
  }
}
