{
  "shell": {
    "tag": "div",
    "classes": [
      "bg-slate-950",
      "min-h-screen",
      "text-slate-100"
    ]
  },
  "header": {
    "tag": "header",
    "classes": [
      "backdrop-blur",
      "bg-slate-900/70",
      "border-b",
      "border-slate-800/70",
      "px-6",
      "py-8",
      "shadow-[0_18px_45px_rgba(8,15,35,0.55)]",
      "sm:px-8"
    ]
  },
  "main": {
    "tag": "main",
    "classes": [
      "max-w-6xl",
      "mx-auto",
      "pb-16",
      "pt-10",
      "px-6",
      "sm:px-8",
      "space-y-8",
      "w-full"
    ]
  },
  "nav": {
    "container": {
      "tag": "nav",
      "classes": [
        "bg-slate-900/60",
        "border",
        "border-slate-800/70",
        "flex",
        "gap-2",
        "items-center",
        "max-w-md",
        "mx-auto",
        "p-1.5",
        "rounded-full",
        "text-sm"
      ]
    },
    "buttons": [
      {
        "text": "Chat",
        "tag": "button",
        "classes": [
          "bg-sky-400",
          "flex-1",
          "focus-visible:outline",
          "focus-visible:outline-2",
          "focus-visible:outline-offset-2",
          "focus-visible:outline-sky-300",
          "font-semibold",
          "px-4",
          "py-2",
          "rounded-full",
          "shadow-[0_12px_30px_rgba(56,189,248,0.35)]",
          "text-slate-950",
          "text-sm",
          "transition"
        ]
      },
      {
        "text": "LogFlow",
        "tag": "button",
        "classes": [
          "flex-1",
          "focus-visible:outline",
          "focus-visible:outline-2",
          "focus-visible:outline-offset-2",
          "focus-visible:outline-sky-300",
          "font-semibold",
          "hover:bg-slate-800/60",
          "hover:text-slate-100",
          "px-4",
          "py-2",
          "rounded-full",
          "text-slate-300",
          "text-sm",
          "transition"
        ]
      }
    ]
  },
  "layout": {
    "tag": "div",
    "classes": [
      "gap-6",
      "grid",
      "xl:grid-cols-[minmax(0,1.7fr)_minmax(0,1fr)]"
    ]
  },
  "conversationPanel": {
    "tag": "section",
    "classes": [
      "bg-slate-900/60",
      "border",
      "border-slate-800/80",
      "p-6",
      "rounded-3xl",
      "shadow-[0_24px_60px_rgba(8,15,35,0.45)]",
      "sm:p-8",
      "space-y-6"
    ]
  },
  "sidebarPanels": {
    "tag": "div",
    "classes": [
      "gap-6",
      "grid"
    ]
  },
  "runStatsPanel": {
    "tag": "section",
    "classes": [
      "bg-slate-900/60",
      "border",
      "border-slate-800/80",
      "p-6",
      "rounded-3xl",
      "shadow-[0_24px_60px_rgba(8,15,35,0.45)]",
      "sm:p-7",
      "space-y-6"
    ]
  },
  "rawResponsePanel": {
    "tag": "section",
    "classes": [
      "bg-slate-900/60",
      "border",
      "border-slate-800/80",
      "p-6",
      "rounded-3xl",
      "shadow-[0_24px_60px_rgba(8,15,35,0.45)]",
      "sm:p-7",
      "space-y-4"
    ]
  },
  "chatLog": {
    "tag": "div",
    "classes": [
      "bg-slate-950/60",
      "border",
      "border-slate-800/70",
      "flex",
      "flex-col",
      "gap-6",
      "max-h-[26rem]",
      "overflow-y-auto",
      "p-4",
      "rounded-2xl",
      "shadow-inner",
      "shadow-slate-950/40"
    ]
  },
  "promptInput": {
    "tag": "textarea",
    "classes": [
      "bg-slate-950/60",
      "bg-slate-950/70",
      "border",
      "border-slate-800/70",
      "border-slate-800/70",
      "focus-visible:outline",
      "focus-visible:outline-2",
      "focus-visible:outline-offset-2",
      "focus-visible:outline-sky-400",
      "min-h-[9rem]",
      "p-4",
      "placeholder:text-slate-500",
      "resize-y",
      "rounded-2xl",
      "shadow-inner",
      "shadow-slate-950/40",
      "text-slate-100",
      "text-sm",
      "w-full"
    ]
  },
  "runButton": {
    "text": "Run",
    "tag": "button",
    "classes": [
      "bg-sky-400",
      "disabled:cursor-not-allowed",
      "disabled:opacity-60",
      "enabled:hover:bg-sky-300",
      "focus-visible:outline",
      "focus-visible:outline-2",
      "focus-visible:outline-offset-2",
      "focus-visible:outline-sky-400",
      "font-semibold",
      "inline-flex",
      "items-center",
      "justify-center",
      "px-5",
      "py-2",
      "rounded-full",
      "sm:w-auto",
      "text-slate-950",
      "text-sm",
      "transition",
      "w-full"
    ]
  },
  "saveButton": {
    "text": "保存对话",
    "tag": "button",
    "classes": [
      "border",
      "border-sky-400/70",
      "disabled:cursor-not-allowed",
      "disabled:opacity-50",
      "enabled:hover:border-sky-300",
      "enabled:hover:text-sky-100",
      "focus-visible:outline",
      "focus-visible:outline-2",
      "focus-visible:outline-offset-2",
      "focus-visible:outline-sky-300",
      "font-semibold",
      "inline-flex",
      "items-center",
      "justify-center",
      "px-5",
      "py-2",
      "rounded-full",
      "text-sky-200",
      "text-sm",
      "transition",
      "whitespace-nowrap"
    ]
  },
  "statusBadge": {
    "tag": "span",
    "classes": [
      "bg-slate-900/70",
      "bg-transparent",
      "border",
      "border-slate-700/60",
      "font-semibold",
      "gap-1",
      "inline-flex",
      "items-center",
      "normal-case",
      "px-2.5",
      "py-0.5",
      "rounded-full",
      "text-[0.65rem]",
      "text-slate-200",
      "text-slate-300",
      "tracking-[0.18em]",
      "uppercase"
    ]
  }
}
